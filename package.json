{
  "name": "catat",
  "version": "0.1.0",
  "private": true,
  "description": "Sistem pencatatan transaksi multi-usaha (offline-first PWA di Cloudflare)",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --filter @catat/web dev",
    "dev:worker": "pnpm --filter @catat/worker dev",
    "build": "pnpm --filter @catat/web build && pnpm --filter @catat/worker build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @catat/shared db:generate",
    "db:migrate:local": "pnpm --filter @catat/worker db:migrate:local",
    "db:migrate:remote": "pnpm --filter @catat/worker db:migrate:remote",
    "deploy": "pnpm build && pnpm --filter @catat/worker deploy"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22"
  }
}
