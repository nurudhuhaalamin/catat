{
  "name": "@catat/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --config ../wrangler.toml",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "deploy": "wrangler deploy --config ../wrangler.toml",
    "db:migrate:local": "wrangler d1 migrations apply catat --local --config ../wrangler.toml",
    "db:migrate:remote": "wrangler d1 migrations apply catat --remote --config ../wrangler.toml",
    "db:seed:local": "wrangler d1 execute catat --local --config ../wrangler.toml --file ../scripts/seed.sql"
  },
  "dependencies": {
    "@catat/shared": "workspace:*",
    "better-auth": "^1.2.7",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.6.3",
    "wrangler": "^4.40.0"
  }
}
